BINANCE_URL=https://api.binance.com
BYBIT_URL=https://api.bybit.com
BINGX_URL=https://open-api.bingx.com

# WebSocket feeds (optional — falls back to REST if absent)
BINANCE_WS_URL=wss://stream.binance.com:9443
BYBIT_WS_URL=wss://stream.bybit.com

# API keys for inventory tracking and order placement (optional — alarm-only mode if absent)
# Binance: read + trade permissions (no withdrawal)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Bybit: read + trade permissions (no withdrawal)
BYBIT_API_KEY=
BYBIT_API_SECRET=
# BingX: read + trade permissions (no withdrawal)
BINGX_API_KEY=
BINGX_API_SECRET=

# Testnet URLs — override the above for dry-run sandbox testing (set dry_run_sandbox: true in config.yaml)
# BINANCE_URL=https://testnet.binance.vision
# BYBIT_URL=https://api-testnet.bybit.com

# Alerting — webhook receives JSON on circuit breaker, execution errors, reconciliation divergence
# Works with Discord, Slack, PagerDuty, ntfy.sh, etc.
ALERT_WEBHOOK_URL=
