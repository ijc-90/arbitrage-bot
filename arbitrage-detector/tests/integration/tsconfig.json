{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "rootDir": "../../"
  },
  "include": ["./**/*.ts"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
